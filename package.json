    "./InputGroup": "./dist/components/InputGroup.js",
    "./NotificationIsland": "./dist/components/NotificationIsland.js",
    "./Icon": "./dist/components/Icon.js",
    "./Checkbox": "./dist/components/Checkbox.js",
    "./Radio": "./dist/components/Radio.js",
    "./RadioGroup": "./dist/components/RadioGroup.js",
    "./Toggle": "./dist/components/Toggle.js",
